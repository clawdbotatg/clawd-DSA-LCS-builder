#!/usr/bin/env python3
"""
Poll LeftClaw Services for Build jobs and dispatch the agent.
No LLM involved — pure deterministic loop.

Model routing: uses minimax-m2.7 for cheap stages (planning, auditing,
deploying) and claude-opus-4.6 only for code-writing stages.
"""

from agent.jobs import JobWatcher

SERVICE_TYPE = 6

OPUS = "claude-opus-4.6"
CHEAP = "minimax-m2.7"

OPUS_STAGES = {
    "master_plan", "break_into_steps",
    "prototype", "contract_fix", "frontend_fix", "full_audit_fix",
    "deploy_contract", "livecontract_fix", "deep_contract_fix",
}

SKILL_URLS = [
    "https://leftclaw.services/admin/skill.md",
    "https://ethskills.com/SKILL.md",
    "https://docs.scaffoldeth.io/SKILL.md",
    "https://www.bgipfs.com/SKILL.md",
]


def _model_for_stage(stage):
    """Pick the model based on job stage. Opus for code writing, cheap for everything else."""
    if stage in OPUS_STAGES:
        return OPUS
    return CHEAP


def build_prompt(job, attempt, resume):
    """Returns (prompt, model) tuple. Always starts fresh — no resume logic."""
    job_id = job["id"]
    client = job.get("client", "unknown")
    stage = job.get("currentStage", "")
    model = _model_for_stage(stage)

    skill_list = "\n".join(f"  - {u}" for u in SKILL_URLS)

    already_accepted = resume or attempt > 1

    prompt = (
        f"You have a Build job to complete. "
        f"Job #{job_id} on LeftClaw Services. Client: {client}. "
        f"\n\n{'This job is already accepted — do NOT call leftclaw_accept_job.' if already_accepted else ''}"
        f"\n\nUse leftclaw_get_job to read the full description, leftclaw_get_messages to check for client messages. "
        f"Note the job.client address — this is who owns everything you build. "
        f"\n\nSTART FRESH. Every run gets its own folder. Your first delegation must find the next "
        f"available folder name under ./builds/ — check for leftclaw-service-job-{job_id}, then "
        f"leftclaw-service-job-{job_id}_2, leftclaw-service-job-{job_id}_3, etc. Use the first name "
        f"that doesn't already exist. Do NOT reuse or resume from any existing folder. "
        f"\n\nFollow the PLANNING-FIRST pipeline: "
        f"\n1. create_repo — Set up the GitHub repo and clone into the fresh folder. "
        f"\n2. master_plan — Scaffold SE2, then delegate writing MASTER_PLAN.md. "
        f"   The planning sub-agent must fetch and read ALL skill docs to understand available patterns: "
        f"\n{skill_list}"
        f"\n   MASTER_PLAN.md must cover: architecture, every contract (with function signatures), "
        f"every frontend page, components, hooks, deploy strategy, security model, and dependencies. "
        f"\n3. break_into_steps — Delegate breaking MASTER_PLAN.md into granular step files in steps/. "
        f"   One step per contract, per page, per audit, per fix, per deployment. Each step file is self-contained. "
        f"\n4. Execute each step in order by delegating them one at a time. "
        f"\n5. Deploy contracts to Base, deploy frontend to BGIPFS. "
        f"\n6. Complete the job with leftclaw_complete_job using the BGIPFS gateway URL. "
        f"\n\nLog work after each stage. The plan files are the source of truth for the whole build."
    )
    return prompt, model


if __name__ == "__main__":
    JobWatcher(
        service_type_id=SERVICE_TYPE,
        prompt_builder=build_prompt,
        poll_interval=60,
        agent_timeout=1800,
        max_retries=3,
    ).run()
